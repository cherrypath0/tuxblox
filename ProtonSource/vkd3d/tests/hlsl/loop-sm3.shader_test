[require]
options: backcompat
shader model >= 3.0

[vertex shader fail(sm<3) todo(sm<3)]
void main(float4 p : position, out float4 position : sv_position, out float4 col[4] : COLOR)
{
    col[0] = float4(1.0, 0.0, 0.0, 1.0);
    col[1] = float4(0.0, 1.0, 0.0, 1.0);
    col[2] = float4(0.0, 0.0, 1.0, 1.0);
    col[3] = float4(0.5, 0.5, 0.5, 1.0);
    position = p;
}

% This shader makes fxc use the aL (loop counter) register.
% This register is to be used on a `loop` instruction -- a variant of `rep` that
% takes it as an argument) to relative address an array of input COLOR
% semantics:
%
%    loop aL, i0
%      add r0, r0, v0[aL]
%    endloop
%
% According to the documentation, for the `loop` instruction, i0.x should be the
% iteration count, i0.y should be the start, i0.z should be the step, and i0.w
% should be zero, but these values are not set in the shader on this example so
% are probably expected to be provided by the user.
% Note that the [loop] attribute is necessary for this to happen, otherwise the
% loop is unrolled.
[pixel shader fail(sm<3) todo(sm<4)]
int limit;

float4 main(float4 pos : sv_position, in float4 cols[4] : COLOR) : sv_target
{
    float4 sum = 0;

    [loop]
    for (int i = 0; i < limit; ++i)
        sum += cols[i];
    return sum;
}

