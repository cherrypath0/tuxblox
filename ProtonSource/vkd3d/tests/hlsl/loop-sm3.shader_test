% This test fails with fxc/d3dcompiler:
%
%     error X3526: can't use gradient instructions in loops with break
%
% This is probably because the `i += 2` increment results in the compiler
% using the break_ge strategy for the loop, but then fails because it
% detects the tex2D() which is an operation that might require gradients.
% This makes sense since, for gradients to work, adjacent pixels must take
% the same flow control path.
[pixel shader fail(sm<4) todo(sm<4)]
sampler sam;
int limit;

float4 main() : sv_target
{
    float4 sum = 0;
    float2 pos;

    [loop]
    for (int i = 0; i < limit; i += 2)
    {
        pos.x = 0.01 + i * 0.25;
        pos.y = 0.01 + i * 0.25;
        sum += tex2D(sam, pos);
    }
    return 0;
}

% If we remove the [loop] attribute we get similar errors:
%
%     warning X3553: can't use gradient instructions in loops with break, forcing loop to unroll
%     error X3511: unable to unroll loop, loop does not appear to terminate in a timely manner (1024 iterations)
%
[pixel shader fail(sm<4) todo(sm<4)]
sampler sam;
int limit;

float4 main() : sv_target
{
    float4 sum = 0;

    for (int i = 0; i < limit; i += 2)
        sum += tex2D(sam, float2(0, 0));
    return 0;
}

[pixel shader fail(sm<4) todo(sm<4)]
sampler sam;
int limit;

float4 main() : sv_target
{
    float4 sum = 0;

    for (int i = 1; i < limit; i++)
        sum += tex2D(sam, float2(0, 0));
    return 0;
}

[pixel shader fail(sm<3) todo(sm<4)]
sampler sam;
int limit; // gets i0.x and c0.x.

float4 main() : sv_target
{
    float4 sum = 0;
    float2 pos;

    for (int i = 0; i < limit; i += 1)
    {
        pos.x = 0.01 + i * 0.25;
        pos.y = 0.01 + i * 0.25;
        sum *= 10;
        sum += tex2D(sam, pos);
    }
    sum.w = limit;
    return sum;
}

