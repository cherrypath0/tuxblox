% This shader forces the use of the aL register, but the shader provides the
% limit, start, step, and zero values using `defi`.
% Note that it acknowledges that the maximum number of iterations is 4 because
% of the size of the `cols` array.
%
%     defi i0, 4, 0, 1, 0
%     ...
%     loop aL, i0
%         mov r0.z, r0.x
%         break_ge r0.y, r0.z
%         add r1, r1, v0[aL]
%         add r0.y, r0.y, c1.z
%     endloop
%     ...
%
[pixel shader fail(sm<3)]
int2 limit;

float4 main(float4 pos : sv_position, in float4 cols[4] : COLOR) : sv_target
{
    float4 sum = 0;

    [loop]
    for (int i = 0; i < limit.x + limit.y; i++)
        sum += cols[i];
    return sum;
}

