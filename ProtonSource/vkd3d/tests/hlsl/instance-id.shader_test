% In TPF and DXIL SV_VertexID and SV_InstanceID always start from zero,
% rather than from the number specified in the API draw call. This is different
% from other APIs, like Metal and Vulkan, so it's useful to check we're
% offsetting properly.

[vertex shader]
static const float2 vertices[3] =
{
    {-1.0f,  1.0f},
    { 3.0f,  1.0f},
    {-1.0f, -3.0f},
};

struct vs_out
{
    float4 position : SV_Position;
    uint vertex_id : vertid;
    uint instance_id : instid;
};

void main(uint id : SV_VertexID, uint inst_id : SV_InstanceID, out vs_out o)
{
    const float2 pos = vertices[id % 3];
    o.position = float4(pos, 0.0f, 1.0f);
    o.vertex_id = id;
    o.instance_id = inst_id;
}

[pixel shader]
struct vs_out
{
    float4 position : SV_Position;
    uint vertex_id : vertid;
    uint instance_id : instid;
};

float4 main(const in vs_out vs) : SV_Target
{
    return float4(vs.vertex_id, vs.instance_id, 0.0, 0.0);
}

