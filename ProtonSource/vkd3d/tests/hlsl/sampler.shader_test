[vertex shader]
void main(float4 pos : position, out float2 tex : texcoord, out float4 out_pos : sv_position)
{
    tex = (pos.xy + 1) / 2;
    out_pos = pos;
}

[pixel shader]
sampler s;
Texture2D t;

float4 main(float2 coord : texcoord) : sv_target
{
    return round(10 * t.Sample(s, coord));
}

