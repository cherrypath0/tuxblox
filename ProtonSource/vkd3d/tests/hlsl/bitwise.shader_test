[pixel shader]
float4 main() : SV_TARGET
{
    int a = 0;
    int b = 0;
    int c = 1;
    int d = 1;

    a ^= 0;
    b ^= 1;
    c ^= 0;
    d ^= 1;

    return float4(a, b, c, d);
}

