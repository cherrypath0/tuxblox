[vb 0]
-1.0 -1.0 0.1 1.2
-1.0  1.0 0.1 2.0
 1.0 -1.0 0.7 1.2
 1.0  1.0 0.7 2.0

[input layout]
0 r32g32b32a32-float POSITION

[vertex shader]
float4 main(float4 pos : POSITION) : sv_position
{
    return pos;
}

[pixel shader fail(sm<4) todo(sm<4)]
float4 main(float4 pos : sv_position) : sv_target
{
    return pos;
}

[test]
clear rtv-0 f32(0.0, 0.0, 0.0, 0.0)
draw triangle strip 4
probe ( 80, 140) f32(  0.0,   0.0, 0.0,         0.0)
probe ( 80, 420) f32( 80.5, 420.5, 0.100678146, 1.229981) 192
probe (180, 140) f32(180.5, 140.5, 0.077760354, 1.918082) 192
probe (180, 420) f32(180.5, 420.5, 0.194427669, 1.229981) 192
probe (460, 140) f32(460.5, 140.5, 0.340260297, 1.918082) 192
probe (460, 420) f32(460.5, 420.5, 0.456926346, 1.229981) 192
probe (560, 140) f32(  0.0,   0.0, 0.0, 0.0)
probe (560, 420) f32(560.5, 420.5, 0.550675929, 1.229981) 192

[require]
% vpos is mapped in sm4 only with the backcompat option.
options: backcompat
shader model < 6.0

% sm3 forbids pos or vpos from being more than 2 components.
[pixel shader fail(sm<4) todo(sm<4)]
float4 main(float4 pos : vpos) : sv_target
{
    return pos;
}

[test]
clear rtv-0 f32(0.0, 0.0, 0.0, 0.0)
draw triangle strip 4
probe ( 80, 140) f32(  0.0,   0.0, 0.0,         0.0)
todo(sm<4) probe ( 80, 420) f32( 80.5, 420.5, 0.100678146, 1.229981) 192
todo(sm<4) probe (180, 140) f32(180.5, 140.5, 0.077760354, 1.918082) 192
todo(sm<4) probe (180, 420) f32(180.5, 420.5, 0.194427669, 1.229981) 192
todo(sm<4) probe (460, 140) f32(460.5, 140.5, 0.340260297, 1.918082) 192
todo(sm<4) probe (460, 420) f32(460.5, 420.5, 0.456926346, 1.229981) 192
probe (560, 140) f32(  0.0,   0.0, 0.0, 0.0)
todo(sm<4) probe (560, 420) f32(560.5, 420.5, 0.550675929, 1.229981) 192

% sm4 forbids sv_position from being any less than 4 components.
[pixel shader fail todo]
float4 main(float3 pos : sv_position) : sv_target
{
    return float4(pos, 0);
}

% vpos is no different.
[pixel shader fail todo(sm>=3)]
float4 main(float3 pos : vpos) : sv_target
{
    return float4(pos, 0);
}

[pixel shader fail(sm<3|sm>=4) todo(sm<3|sm>=4)]
float4 main(float2 pos : sv_position) : sv_target
{
    return float4(pos, 0, 0);
}

[test]
clear rtv-0 f32(0.0, 0.0, 0.0, 0.0)
draw triangle strip 4
          probe ( 80, 140) f32(  0.0,   0.0, 0.0, 0.0)
if(sm<4)  probe ( 80, 420) f32( 80.0, 420.0, 0.0, 0.0)
if(sm>=4) probe ( 80, 420) f32( 80.5, 420.5, 0.0, 0.0)

[pixel shader fail(sm<3|sm>=4) todo(sm<3|sm>=4)]
float4 main(float pos : sv_position) : sv_target
{
    return float4(pos, 0, 0, 0);
}

[test]
clear rtv-0 f32(0.0, 0.0, 0.0, 0.0)
draw triangle strip 4
          probe ( 80, 140) f32(  0.0, 0.0, 0.0, 0.0)
if(sm<4)  probe ( 80, 420) f32( 80.0, 0.0, 0.0, 0.0)
if(sm>=4) probe ( 80, 420) f32( 80.5, 0.0, 0.0, 0.0)
