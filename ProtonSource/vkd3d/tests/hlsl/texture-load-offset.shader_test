0.0 2.0 0.0 1.0     1.0 2.0 0.0 1.0     2.0 2.0 0.0 1.0


[pixel shader]
Texture2D t;

float4 main(float4 pos : sv_position) : sv_target
{
    return t.Load(int3(pos.xy, 0), int2(0, 1));
}


