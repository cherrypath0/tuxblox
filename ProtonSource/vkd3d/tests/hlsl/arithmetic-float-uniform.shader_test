% precise mad() where the first component is not x.
[pixel shader fail(sm<2)]
uniform float4 a, b, c;

float4 main() : sv_target
{
    precise float4 r = float4(c.zw * c.zw, mad(b.xy, b.zw, c.xy));

    return r * a;
}

