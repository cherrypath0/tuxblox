[pixel shader]
uniform min16float u[2];
uniform uint i;

float4 main() : sv_target
{
    min16float arr[4] = {1.0, 2.0, 10.0, 0.5};
    return float4(u[0] + arr[i], u[1] + arr[i + 1], 0, 0);
}

