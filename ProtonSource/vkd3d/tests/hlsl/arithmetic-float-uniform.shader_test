% Test result when instructions might be removed because they are identities such as (+0) or (*1).
[pixel shader]
float4 a;

float4 main() : sv_target
{
    float4 zero = {0, 0, 0, 0};
    float4 one = {1, 1, 1, 1};

    return a + zero + a * one + zero * one;
}

