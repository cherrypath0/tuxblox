[pixel shader]
uniform float4 a;

float4 main() : sv_target
{
    float4 ret;
    ret.x = floor(floor(a.x));
    ret.y = floor(ceil(a.y));
    ret.z = ceil(floor(a.z));
    ret.w = ceil(ceil(a.w));
    return ret;
}

