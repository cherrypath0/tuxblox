[vertex shader]
struct vertex
{
    float4 pos : SV_POSITION;
    float clip[2] : SV_CLIPDISTANCE;
};

void main(float4 pos : POSITION, out vertex vertex)
{
    vertex.pos = pos;
    vertex.clip[0] = pos.x;
    vertex.clip[1] = 1.0;
}

