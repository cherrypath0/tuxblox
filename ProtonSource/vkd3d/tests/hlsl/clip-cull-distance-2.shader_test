% Both FXC and DXC allow declaring a SV_CLIPDISTANCE semantic as an array, but
% only DXC allows indirect addressing of such an array.

% On Windows and SM6 these tests yield different results on WARP, NVIDIA, and
% AMD. The different obtained results suggest that each platform confuses the
% clip[0] and clip[1] values in different ways. The DXIL output from DXC seems
% correct, so perhaps these drivers don't account for the possibility of
% addressing the two registers reserved for both SV_CLIPDISTANCE and
% SV_CULLDISTANCE as a single array.

% We still test that we are generating the expectable results when
% transforming DXIL to the GLSL, SPIR-V, and MSL backends though, matching (or
% extrapolating, in case of indirect addressing) the SM4 behaviour.

[require]
shader model >= 4.0

[vertex shader]
struct vertex
{
    float4 pos : SV_POSITION;
    float2 clip[2] : SV_CLIPDISTANCE;
};

void main(float4 pos : POSITION, out vertex vertex)
{
    vertex.pos = pos;
    // Only pixels closer to the center should remain.
    vertex.clip[0] = float2(0.5 + pos.x, 0.5 - pos.x);
    vertex.clip[1] = float2(0.5 + pos.y, 0.5 - pos.y);
}

[pixel shader]
struct vertex
{
    float4 pos : SV_POSITION;
    float2 clip[2] : SV_CLIPDISTANCE;
};

float4 main(in vertex vert) : SV_TARGET
{
    return round(10000 * float4(vert.clip[0], vert.clip[1]));
}

[test]
clear rtv-0 f32(0.0, 0.0, 0.0, 1.0)
todo(glsl | msl) draw quad
             winbug(sm>=6 & !amd) probe ( 80,  60) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe ( 80, 180) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe ( 80, 300) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe ( 80, 420) f32(0.0, 0.0, 0.0, 1.0)
todo(opengl) winbug(sm>=6 & !amd) probe (240,  60) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe (240, 180) f32(2516, 7484, 7479, 2521)
             winbug(sm>=6 & !amd) probe (240, 300) f32(2516, 7484, 2479, 7521)
todo(opengl) winbug(sm>=6 & !amd) probe (240, 420) f32(0.0, 0.0, 0.0, 1.0)
todo(opengl) winbug(sm>=6 & !amd) probe (400,  60) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe (400, 180) f32(7516, 2484, 7479, 2521)
             winbug(sm>=6 & !amd) probe (400, 300) f32(7516, 2484, 2479, 7521)
todo(opengl) winbug(sm>=6 & !amd) probe (400, 420) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe (560,  60) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe (560, 180) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe (560, 300) f32(0.0, 0.0, 0.0, 1.0)
             winbug(sm>=6 & !amd) probe (560, 420) f32(0.0, 0.0, 0.0, 1.0)

[pixel shader]
float4 main() : SV_TARGET
{
    return float4(1.0, 1.0, 1.0, 1.0);
}

[vertex shader]
struct vertex
{
    float4 pos : SV_POSITION;
    float clip[2] : SV_CLIPDISTANCE;
};

void main(float4 pos : POSITION, out vertex vertex)
{
    vertex.pos = pos;
    vertex.clip[0] = 1.0;
    vertex.clip[1] = pos.y;
}

