[uav 1]
format r32-typeless
size (raw_buffer, 8)

1 0 0 0 2 0 0 0

[compute shader]
RWByteAddressBuffer u : register(u1);
groupshared uint4 m;

    [numthreads(32, 1, 1)]
void main(uint local_idx : SV_GroupIndex, uint group_id : SV_GroupID)
{
    if (!local_idx)
        m = group_id.x;
    GroupMemoryBarrierWithGroupSync();
    InterlockedAdd(m[local_idx % 4], group_id.x + local_idx);
    InterlockedAdd(m.z, local_idx * 10);
    GroupMemoryBarrierWithGroupSync();
    if (!local_idx)
        u.Store4(16 * group_id.x, m);
}

