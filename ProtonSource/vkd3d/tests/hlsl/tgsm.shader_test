[uav 1]
format r32-typeless
size (raw_buffer, 8)

1 0 2 0 3 0 4 0

[compute shader]
RWByteAddressBuffer u : register(u1);
groupshared uint4x4 m;

    [numthreads(32, 1, 1)]
void main(uint local_idx : SV_GroupIndex, uint group_id : SV_GroupID)
{
    if (!local_idx)
    {
        m = group_id.x;
    }
    GroupMemoryBarrierWithGroupSync();
    InterlockedAdd(m[local_idx / 4][local_idx % 4], group_id.x + local_idx);
    InterlockedAdd(m._m00, local_idx * 10);
    InterlockedAdd(m[1].y, local_idx * 100);
    GroupMemoryBarrierWithGroupSync();
    if (!local_idx)
    {
        u.Store(8 * group_id.x, m[0][0]);
        u.Store(8 * group_id.x + 4, m[1][1]);
    }
}

