[pixel shader]
    static float4 func();

    static float4 func() { return 1; }

    float4 main();
    export float4 main() : sv_target
    {
        return func();
    }

% 'static' prevents the function from being considered for the entry point.
[pixel shader fail]
    static float4 main() : sv_target
    {
        return 0;
    }

% sm6 apparently doesn't allow overloading the entry point, even though it
% allows other overloads.
[pixel shader fail(sm>=6)]
    static float4 main() : sv_target
    {
        return 0;
    }

    float4 main(float f : texcoord) : sv_target
    {
        return 1;
    }

% 'static' and 'export' are mutually exclusive in sm6.
% Earlier versions allow them, but only in the order 'export static'.
[pixel shader fail todo]
    static export void func() {}

    float4 main() : sv_target
    {
        return 0;
    }

[pixel shader fail(sm>=6)]
    export static void func() {}

    float4 main() : sv_target
    {
        return 0;
    }

% 'static' has to match between declarations and definitions.
% 'export' does not, as shown in the first test.
[pixel shader fail(sm<6)]
    static void func();
    void func() {}

    float4 main() : sv_target
    {
        return 0;
    }

[pixel shader fail]
    void func();
    static void func() {}

    float4 main() : sv_target
    {
        return 0;
    }
