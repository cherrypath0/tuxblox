[vertex shader]
void main(float4 p : position, out float t[4] : texcoord, out float4 position : sv_position)
{
    t[0] = (p.x + 1.0) / 2.0;
    t[2] = 0.0;
    t[1] = (p.y + 1.0) / 2.0;
    t[3] = 1.0;
    position = p;
}

[pixel shader]
float4 main(float t[4] : texcoord) : sv_target
{
    if (t[0] > 0.5)
        return floor(float4(t) * 128.0 + 0.5) / 128.0;
    return float4(0.0, 1.0, 0.0, 1.0);
}

