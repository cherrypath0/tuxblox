[pixel shader fail]
float4 u;

float main() : sv_target
{
    [branch] [flatten]
    if (u.x > 0.0)
        return float4(0.1, 0.2, 0.3, 0.4);
    else
        return float4(0.9, 0.8, 0.7, 0.6);
