[header]
test-shader-models (2.0 3.0 6.0 6.2)

[pixel shader]
uniform float4 u;

float4 main() : sv_target
{
    if (u.x > 0.0)
        return float4(0.1, 0.2, 0.3, 0.4);
    else
        return float4(0.9, 0.8, 0.7, 0.6);
}

