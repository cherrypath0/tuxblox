% Branches with resource stores can't be flattened.
[pixel shader fail(sm<6)]
uniform float a;
RWBuffer<float> u;

float4 main() : sv_target
{
    [flatten]
    if (a > 0)
       u[0] = a;
    return a;
}

[pixel shader fail(sm<6) todo]
uniform float a;
uniform uint b;
RWBuffer<float> u;

float4 main() : sv_target
{
    [flatten]
    if (a > 0)
    {
       for (uint i = 0; i < b; ++i)
       {
           if (i > 3)
               u[i] = a + i;
       }
    }
    return a;
}

% Test 16-bit phi instructions.
[require]
shader model >= 6.2
native-16-bit

[pixel shader]
Texture2D<half4> tex;
float a;

half4 main() : sv_target
{
    if (a >= 2)
        return tex.Load(int3(0, 0, 0));
    else
        return half(a);
}

