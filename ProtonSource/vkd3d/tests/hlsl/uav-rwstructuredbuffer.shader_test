[compute shader]
struct apple
{
    float3 a;
    float2 b;
};
typedef apple pie[3]; // pie is an array of 3 apples.

RWStructuredBuffer<pie> buf : register(u2);

    [numthreads(1, 1, 1)]
void main()
{
    struct apple aps[3] = {
            11, 12, 13, 14, 15,
            21, 22, 23, 24, 25,
            31, 32, 33, 34, 35};

    buf[1] = aps; // whole-array assignment.
}

